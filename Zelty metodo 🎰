-- [[ ZELTY HUB ❄️ - VERSÃO TURBO AZUL ]]

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- Serviços
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local VirtualUser = game:GetService("VirtualUser")
local Player = Players.LocalPlayer

-- Remote
local ClaimReward = ReplicatedStorage
    :WaitForChild("Packages")
    :WaitForChild("_Index")
    :WaitForChild("sleitnick_knit@1.7.0")
    :WaitForChild("knit")
    :WaitForChild("Services")
    :WaitForChild("ChallengeService")
    :WaitForChild("RF")
    :WaitForChild("ClaimReward")

local Window = Rayfield:CreateWindow({
   Name = "Zelty Hub ❄️",
   LoadingTitle = "Modo Turbo Ativado",
   LoadingSubtitle = "por gbbatista",
   ConfigurationSaving = { Enabled = true, FolderName = "ZeltyHubData", FileName = "ZeltyConfig" },
   Theme = "Ocean",
   KeySystem = false
})

local Tab1 = Window:CreateTab("LuckySpin", 4483362458) 
local Section1 = Tab1:CreateSection("Recompensas (MODO RÁPIDO)")

-- [[ AUTO LUCK SPIN TURBO ]]
local AutoLuckEnabled = false
local Toggle1 = Tab1:CreateToggle({
   Name = "🏆 Auto Coletar (MODO RÁPIDO)",
   CurrentValue = false,
   Flag = "ToggleAutoCollect",
   Callback = function(Value)
      AutoLuckEnabled = Value
      if Value then
          task.spawn(function()
              local i = 1
              while AutoLuckEnabled do
                  -- pcall evita que o script pare se houver lag no servidor
                  pcall(function()
                      ClaimReward:InvokeServer(i)
                  end)
                  
                  i = (i >= 500) and 1 or i + 1 -- Diminuí o limite para resetar o loop mais rápido
                  
                  -- task.wait() vazio é a velocidade máxima do frame (aprox. 0.01s)
                  task.wait() 
              end
          end)
      end
   end,
})

-- [[ PITY BUGADA TURBO ]]
local PityEnabled = false
local Toggle3 = Tab1:CreateToggle({
   Name = "⚡ Pity Bugada (MÁX SPEED)",
   CurrentValue = false,
   Flag = "TogglePityBug",
   Callback = function(Value)
      PityEnabled = Value
      if Value then
          task.spawn(function()
              while PityEnabled do
                  pcall(function()
                      ClaimReward:InvokeServer(1)
                  end)
                  -- Sem tempo de espera (CUIDADO: Pode causar lag se o servidor for ruim)
                  task.wait() 
              end
          end)
      end
   end,
})

-- [[ ABA JOGADOR ]]
local Tab2 = Window:CreateTab("Jogador", 4483362458)
local Section2 = Tab2:CreateSection("Estatísticas")

local Toggle4 = Tab2:CreateToggle({
   Name = "👤 Modo Anônimo",
   CurrentValue = false,
   Flag = "ToggleAnonMode",
   Callback = function(Value)
      if Value then pcall(function() Player.DisplayName = "User_" .. math.random(1000, 9999) end) end
   end,
})

local AntiAFKEnabled = false
local Toggle5 = Tab2:CreateToggle({
   Name = "💤 Anti-AFK",
   CurrentValue = false,
   Flag = "ToggleAntiAFK",
   Callback = function(Value)
      AntiAFKEnabled = Value
      if Value then
          Player.Idled:Connect(function()
              if AntiAFKEnabled then
                  VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
                  task.wait(1)
                  VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
              end
          end)
      end
   end,
})

Rayfield:Notify({
   Title = "Zelty Turbo!",
   Content = "Velocidade de coleta aumentada.",
   Duration = 5,
   Image = 4483362458,
})
