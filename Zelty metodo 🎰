local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local VirtualUser = game:GetService("VirtualUser")
local VIM = game:GetService("VirtualInputManager")
local Player = Players.LocalPlayer

local ClaimReward = ReplicatedStorage:WaitForChild("Packages"):WaitForChild("_Index"):WaitForChild("sleitnick_knit@1.7.0"):WaitForChild("knit"):WaitForChild("Services"):WaitForChild("ChallengeService"):WaitForChild("RF"):WaitForChild("ClaimReward")

local Window = Rayfield:CreateWindow({
   Name = "Volleyball Legends | Zelty Hub",
   LoadingTitle = "Zelty Hub Turbo ⚡",
   LoadingSubtitle = "by gbbatista",
   ConfigurationSaving = { Enabled = false }, 
   Theme = "Ocean",
   KeySystem = false,
   DisableRayfieldPrompts = true
})

-- [[ ABA RECOMPENSAS ]]
local Tab1 = Window:CreateTab("LuckySpin", 4483362458) 

local AutoLuckEnabled = false
Tab1:CreateToggle({
   Name = "🍀 Auto Luck Spin",
   CurrentValue = false,
   Flag = "LSpinV4", 
   Callback = function(Value)
      AutoLuckEnabled = Value
      if Value then
          Rayfield:Notify({Title = "🍀 LUCKY SPIN", Content = "Farm ativado com sucesso!", Duration = 3})
          task.spawn(function()
              local i = 1
              while AutoLuckEnabled do
                  pcall(function() ClaimReward:InvokeServer(unpack({i})) end)
                  i = (i >= 1000) and 1 or i + 1
                  task.wait(0.01) 
              end
          end)
      end
   end,
})

Tab1:CreateToggle({
   Name = "🔒 Anti-Ban",
   CurrentValue = false,
   Flag = "ABanV4",
   Callback = function(Value)
      if Value then Rayfield:Notify({Title = "🔒 BYPASS", Content = "Proteção anti-ban ativa", Duration = 4}) end
   end,
})

-- [[ ABA JOGADOR ]]
local Tab2 = Window:CreateTab("Jogador", 4483362458)

Tab2:CreateSlider({
   Name = "⚡ Velocidade (WalkSpeed)",
   Range = {16, 200},
   Increment = 1,
   Suffix = "Speed",
   CurrentValue = 16,
   Flag = "Slider1",
   Callback = function(Value)
      Player.Character.Humanoid.WalkSpeed = Value
   end,
})

Tab2:CreateSlider({
   Name = "🚀 Pulo (JumpPower)",
   Range = {50, 300},
   Increment = 1,
   Suffix = "Power",
   CurrentValue = 50,
   Flag = "Slider2",
   Callback = function(Value)
      Player.Character.Humanoid.JumpPower = Value
   end,
})

local AnonEnabled = false
Tab2:CreateToggle({
   Name = "👤 Modo Anônimo",
   CurrentValue = false,
   Flag = "AnonV4",
   Callback = function(Value)
      AnonEnabled = Value
      if Value then
          Rayfield:Notify({Title = "👤 ANÔNIMO", Content = "Tags ocultadas visualmente!", Duration = 3})
          task.spawn(function()
              while AnonEnabled do
                  pcall(function()
                      Player.DisplayName = "Zelty"
                      if Player.Character and Player.Character:FindFirstChild("Head") then
                          for _, v in pairs(Player.Character.Head:GetChildren()) do
                              if v:IsA("BillboardGui") then v.Enabled = false end
                          end
                      end
                  end)
                  task.wait(1)
              end
          end)
      end
   end,
})

local AntiAFKEnabled = false
Tab2:CreateToggle({
   Name = "💤 Anti-AFK",
   CurrentValue = false,
   Flag = "AfkV4",
   Callback = function(Value)
      AntiAFKEnabled = Value
      if Value then
          if getgenv().AFK_Zelty then getgenv().AFK_Zelty:Disconnect() end
          getgenv().AFK_Zelty = Player.Idled:Connect(function()
              if AntiAFKEnabled then
                  VIM:SendKeyEvent(true, Enum.KeyCode.RightControl, false, game)
                  task.wait(0.1)
                  VIM:SendKeyEvent(false, Enum.KeyCode.RightControl, false, game)
              end
          end)
          Rayfield:Notify({Title = "💤 ANTI-AFK", Content = "Anti-Kick ativo!", Duration = 3})
      end
   end,
})

