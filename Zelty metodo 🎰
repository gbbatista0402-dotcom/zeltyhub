-- TOGGLE
local function createToggle(name, posY, callback)
	local Frame = Instance.new("Frame", Main)
	Frame.Size = UDim2.new(1, -40, 0, 50)
	Frame.Position = UDim2.new(0, 20, 0, posY)
	Frame.BackgroundColor3 = Color3.fromRGB(20, 40, 70)
	Frame.BorderSizePixel = 0
	Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 12)

	local Label = Instance.new("TextLabel", Frame)
	Label.Size = UDim2.new(0.7, 0, 1, 0)
	Label.Position = UDim2.new(0, 10, 0, 0)
	Label.Text = name
	Label.BackgroundTransparency = 1
	Label.TextColor3 = Color3.fromRGB(255,255,255)
	Label.Font = Enum.Font.Gotham
	Label.TextSize = 14
	Label.TextXAlignment = Enum.TextXAlignment.Left

	local Toggle = Instance.new("TextButton", Frame)
	Toggle.Size = UDim2.new(0, 60, 0, 25)
	Toggle.Position = UDim2.new(1, -70, 0.5, -12)
	Toggle.BackgroundColor3 = Color3.fromRGB(50, 80, 120)
	Toggle.Text = "OFF"
	Toggle.TextColor3 = Color3.new(1,1,1)
	Toggle.Font = Enum.Font.GothamBold
	Toggle.TextSize = 12
	Instance.new("UICorner", Toggle).CornerRadius = UDim.new(1, 0)

	local enabled = false

	Toggle.MouseButton1Click:Connect(function()
		enabled = not enabled
		
		Toggle.Text = enabled and "ON" or "OFF"
		Toggle.BackgroundColor3 = enabled and Color3.fromRGB(0,170,255) or Color3.fromRGB(50,80,120)

		createNotification(name .. ": " .. (enabled and "ON" or "OFF"))
		
		if callback then
			callback(function() return enabled end)
		end
	end)
end

