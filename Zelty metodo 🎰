local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local VirtualUser = game:GetService("VirtualUser")
local VIM = game:GetService("VirtualInputManager")
local Player = Players.LocalPlayer

local ClaimReward = ReplicatedStorage:WaitForChild("Packages"):WaitForChild("_Index"):WaitForChild("sleitnick_knit@1.7.0"):WaitForChild("knit"):WaitForChild("Services"):WaitForChild("ChallengeService"):WaitForChild("RF"):WaitForChild("ClaimReward")

local Window = Rayfield:CreateWindow({
   Name = "Volleyball Legends | Zelty Hub",
   LoadingTitle = "Zelty Hub Turbo",
   LoadingSubtitle = "by gbbatista",
   ConfigurationSaving = { Enabled = false }, -- Desliguei o save automático para limpar o bug visual
   Theme = "Ocean",
   KeySystem = false,
   DisableRayfieldPrompts = true
})

local Tab1 = Window:CreateTab("LuckySpin", 4483362458) 

local AutoLuckEnabled = false
Tab1:CreateToggle({
   Name = "🍀 Auto Luck Spin",
   CurrentValue = false,
   Flag = "LuckFix", 
   Callback = function(Value)
      AutoLuckEnabled = Value
      if Value then
          Rayfield:Notify({Title = "🍀 LUCKY SPIN", Content = "Farm iniciado!", Duration = 3})
          task.spawn(function()
              local i = 1
              while AutoLuckEnabled do
                  pcall(function() ClaimReward:InvokeServer(unpack({i})) end)
                  i = (i >= 1000) and 1 or i + 1
                  task.wait(0.01) 
              end
          end)
      end
   end,
})

Tab1:CreateToggle({
   Name = "🔒 Anti-Ban",
   CurrentValue = false, -- Começa desligado para não bugar o visual
   Flag = "BanFix",
   Callback = function(Value)
      if Value then Rayfield:Notify({Title = "🔒 BYPASS", Content = "Proteção 80% segura ativada", Duration = 4}) end
   end,
})

local Tab2 = Window:CreateTab("Jogador", 4483362458)

local AnonEnabled = false
Tab2:CreateToggle({
   Name = "👤 Modo Anônimo",
   CurrentValue = false,
   Flag = "AnonFix",
   Callback = function(Value)
      AnonEnabled = Value
      if Value then
          task.spawn(function()
              while AnonEnabled do
                  pcall(function()
                      Player.DisplayName = "Zelty"
                      if Player.Character and Player.Character:FindFirstChild("Head") then
                          for _, v in pairs(Player.Character.Head:GetChildren()) do
                              if v:IsA("BillboardGui") then v.Enabled = false end
                          end
                      end
                  end)
                  task.wait(1)
              end
          end)
      end
   end,
})

local AntiAFKEnabled = false
Tab2:CreateToggle({
   Name = "💤 Anti-AFK",
   CurrentValue = false,
   Flag = "AfkFix", -- Mudei a flag para resetar o brilho azul
   Callback = function(Value)
      AntiAFKEnabled = Value
      if Value then
          if getgenv().AFK_Zelty then getgenv().AFK_Zelty:Disconnect() end
          getgenv().AFK_Zelty = Player.Idled:Connect(function()
              if AntiAFKEnabled then
                  VIM:SendKeyEvent(true, Enum.KeyCode.RightControl, false, game)
                  task.wait(0.1)
                  VIM:SendKeyEvent(false, Enum.KeyCode.RightControl, false, game)
              end
          end)
          Rayfield:Notify({Title = "💤 ANTI-AFK", Content = "Sistema Anti-Kick ativo!", Duration = 3})
      end
   end,
})

local Tab3 = Window:CreateTab("Config", 4483362458)

Tab3:CreateDropdown({
   Name = "Mudar Cor do Script",
   Options = {"Ocean","Amethyst","Green","Amber","DarkBlue"},
   CurrentOption = {"Ocean"},
   MultipleOptions = false,
   Flag = "ThemeFix",
   Callback = function(Option)
      -- Novo método para mudar tema no Xeno sem erro
      local themeName = type(Option) == "table" and Option[1] or Option
      pcall(function()
          Rayfield:ChangeTheme(themeName)
      end)
   end,
})

Tab3:CreateButton({
   Name = "Fechar Script (Destroy)",
   Callback = function() Rayfield:Destroy() end,
})

Rayfield:Notify({
   Title = "Zelty Hub",
   Content = "Menu Limpo e Pronto!",
   Duration = 3,
   Image = 4483362458,
})
