local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local VirtualUser = game:GetService("VirtualUser")
local VIM = game:GetService("VirtualInputManager")
local Player = Players.LocalPlayer

local ClaimReward = ReplicatedStorage:WaitForChild("Packages"):WaitForChild("_Index"):WaitForChild("sleitnick_knit@1.7.0"):WaitForChild("knit"):WaitForChild("Services"):WaitForChild("ChallengeService"):WaitForChild("RF"):WaitForChild("ClaimReward")

local Window = Rayfield:CreateWindow({
   Name = "Volleyball Legends | Zelty Hub",
   LoadingTitle = "Zelty Hub Turbo",
   LoadingSubtitle = "by gbbatista",
   ConfigurationSaving = { Enabled = true, FolderName = "ZeltyHubData", FileName = "ZeltyConfig" },
   Theme = "Ocean",
   KeySystem = false
})

local Tab1 = Window:CreateTab("LuckySpin", 4483362458) 

local AutoLuckEnabled = false
Tab1:CreateToggle({
   Name = "🍀 Auto Luck Spin",
   CurrentValue = false,
   Flag = "Toggle1",
   Callback = function(Value)
      AutoLuckEnabled = Value
      if Value then
          Rayfield:Notify({Title = "🍀 LUCKY SPIN", Content = "Farming de recompensas ligado!", Duration = 3})
          task.spawn(function()
              local i = 1
              while AutoLuckEnabled do
                  pcall(function() ClaimReward:InvokeServer(unpack({i})) end)
                  i = (i >= 1000) and 1 or i + 1
                  task.wait(0.01) 
              end
          end)
      end
   end,
})

Tab1:CreateToggle({
   Name = "🔒 Anti-Ban",
   CurrentValue = true,
   Flag = "Toggle2",
   Callback = function(Value)
      if Value then Rayfield:Notify({Title = "🔒 BYPASS", Content = "Proteção anti-ban ativa (80% seguro)", Duration = 4}) end
   end,
})

local PityEnabled = false
Tab1:CreateToggle({
   Name = "⚡ Pity Bugada",
   CurrentValue = false,
   Flag = "Toggle3",
   Callback = function(Value)
      PityEnabled = Value
      if Value then
          Rayfield:Notify({Title = "⚡ PITY BUG", Content = "Reset de pity ativado!", Duration = 3})
          task.spawn(function() while PityEnabled do pcall(function() ClaimReward:InvokeServer(1) end) task.wait(0.05) end end)
      end
   end,
})

local Tab2 = Window:CreateTab("Jogador", 4483362458)

local AnonEnabled = false
Tab2:CreateToggle({
   Name = "👤 Modo Anônimo",
   CurrentValue = false,
   Flag = "Toggle4",
   Callback = function(Value)
      AnonEnabled = Value
      if Value then
          Rayfield:Notify({Title = "👤 ANÔNIMO", Content = "Ocultando seu nick localmente...", Duration = 3})
          task.spawn(function()
              while AnonEnabled do
                  pcall(function()
                      Player.DisplayName = "ZeltyPlayer"
                      if Player.Character and Player.Character:FindFirstChild("Head") then
                          for _, v in pairs(Player.Character.Head:GetChildren()) do
                              if v:IsA("BillboardGui") or v:IsA("TextLabel") then v.Enabled = false end
                          end
                      end
                  end)
                  task.wait(1)
              end
          end)
      end
   end,
})

local AntiAFKEnabled = false
Tab2:CreateToggle({
   Name = "💤 Anti-AFK",
   CurrentValue = false,
   Flag = "Toggle5",
   Callback = function(Value)
      AntiAFKEnabled = Value
      if Value then
          Rayfield:Notify({Title = "💤 ANTI-AFK", Content = "Anti-Kick ativado com sucesso!", Duration = 3})
          if getgenv().AntiAFK_Zelty then getgenv().AntiAFK_Zelty:Disconnect() end
          getgenv().AntiAFK_Zelty = Player.Idled:Connect(function()
              if AntiAFKEnabled then
                  VIM:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
                  task.wait(0.1)
                  VIM:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
              end
          end)
      end
   end,
})

local Tab3 = Window:CreateTab("Config", 4483362458)

Tab3:CreateDropdown({
   Name = "Mudar Cor do Script",
   Options = {"Ocean","Amethyst","Green","Amber","DarkBlue","Serenity"},
   CurrentOption = {"Ocean"},
   MultipleOptions = false,
   Flag = "ThemeDrop",
   Callback = function(Option)
      local selectedTheme = type(Option) == "table" and Option[1] or Option
      -- Usando task.spawn para evitar o Callback Error no Xeno
      task.spawn(function()
          pcall(function() Rayfield:ChangeTheme(selectedTheme) end)
          pcall(function() Window:ModifyTheme(selectedTheme) end)
      end)
   end,
})

Tab3:CreateButton({
   Name = "Fechar Script (Destroy)",
   Callback = function() Rayfield:Destroy() end,
})

Tab3:CreateButton({
   Name = "Copiar Link do Discord",
   Callback = function()
      setclipboard("https://discord.gg/zeltyhub")
      Rayfield:Notify({Title = "Discord", Content = "Link copiado para o seu teclado!", Duration = 3})
   end,
})

Rayfield:Notify({
   Title = "Zelty Hub",
   Content = "Carregado e Pronto para o Xeno!",
   Duration = 3,
   Image = 4483362458,
})
